nvim/nvim/plugin/

# Zsh local overrides (secrets, host-specific config)
zsh/.zshenv.local

# Sisyphus agent drafts and plans
.sisyphus/

# Vim plugin directory - installed by vim-plug
vim/.vim/plugged/

# OMC (OhMyOpenCode) state files
.omc/

# Vite build output
dist/
.vite/


# Understand-Anything generated files
.understand-anything/
# Machine-local state (not tracked in dotfiles)
omp/.omp/agent/*.db
omp/.omp/agent/*.db-shm
omp/.omp/agent/*.db-wal
omp/.omp/agent/sessions/
omp/.omp/agent/terminal-sessions/
omp/.omp/gpu_cache.json
omp/.omp/logs/
omp/.omp/natives/