{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json",
  "google_auth": false,
  "model_fallback": true,
  "parallel_execution": true,
  "agents": {
    "sisyphus": {
      "model": "ollama-cloud/kimi-k2.5",
      "fallback_models": [
        "ollama-cloud/glm-5",
        "ollama-cloud/minimax-k2.5"
      ]
    },
    "sisyphus-junior": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": [
        "ollama-cloud/nemotron-3-nano"
      ]
    },
    "prometheus": {
      "model": "ollama-cloud/kimi-k2.5",
      "fallback_models": [
        "ollama-cloud/glm-5",
        "ollama-cloud/minimax-k2.5"
      ]
    },
    "atlas": {
      "model": "ollama-cloud/kimi-k2.5",
      "fallback_models": [
        "ollama-cloud/glm-5",
        "ollama-cloud/minimax-m2.5"
      ]
    },
    "hephaestus": {
      "model": "ollama-cloud/qwen3-coder-next",
      "fallback_models": [
        "ollama-cloud/nemotron-3-super",
        "ollama-cloud/kimi-k2.5"
      ]
    },
    "oracle": {
      "model": "ollama-cloud/nemotron-3-super",
      "variant": "high",
      "fallback_models": [
        "ollama-cloud/minimax-k2.5",
        "ollama-cloud/glm-5"
      ]
    },
    "librarian": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": [
        "ollama-cloud/nemotron-3-nano",
        "ollama-cloud/glm-5"
      ]
    },
    "explore": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": [
        "ollama-cloud/nemotron-3-nano"
      ]
    },
    "metis": {
      "model": "ollama-cloud/glm-5",
      "fallback_models": [
        "ollama-cloud/kimi-k2.5",
        "ollama-cloud/minimax-m2.5"
      ]
    },
    "momus": {
      "model": "ollama-cloud/nemotron-3-super",
      "variant": "high",
      "fallback_models": [
        "ollama-cloud/minimax-k2.5",
        "ollama-cloud/glm-5"
      ]
    },
    "frontend-ui-ux-engineer": {
      "model": "ollama-cloud/gemini-3-flash-preview",
      "fallback_models": [
        "ollama-cloud/qwen3.5",
        "ollama-cloud/minimax-m2.5"
      ]
    },
    "document-writer": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": [
        "ollama-cloud/qwen3.5"
      ]
    },
    "multimodal-looker": {
      "model": "ollama-cloud/kimi-k2.5",
      "fallback_models": [
        "ollama-cloud/qwen3.5",
        "ollama-cloud/gemini-3-flash-preview"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "unspecified-low": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "unspecified-high": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "deep": {
      "model": "ollama-cloud/qwen3-coder-next"
    },
    "ultrabrain": {
      "model": "ollama-cloud/nemotron-3-super",
      "variant": "high"
    },
    "artistry": {
      "model": "ollama-cloud/gemini-3-flash-preview"
    },
    "writing": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "visual-engineering": {
      "model": "ollama-cloud/gemini-3-flash-preview"
    }
  }
}
