{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "model_fallback": true,
  "parallel_execution": true,
  "agents": {
    "sisyphus": {
      "model": "ollama-cloud/glm-5"
    },
    "sisyphus-junior": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "prometheus": {
      "model": "openai/gpt-5.3-codex",
      "fallback_models": ["ollama-cloud/kimi-k2.5", "ollama-cloud/glm-5"]
    },
    "atlas": {
      "model": "ollama-cloud/glm-5"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "fallback_models": ["ollama-cloud/glm-5", "ollama-cloud/kimi-k2.5"]
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "fallback_models": ["ollama-cloud/kimi-k2.5", "ollama-cloud/glm-5"]
    },
    "librarian": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "explore": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "metis": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "frontend-ui-ux-engineer": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "document-writer": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "multimodal-looker": {
      "model": "ollama-cloud/minimax-m2.5"
    }
  },
  "categories": {
    "quick": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "unspecified-low": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "unspecified-high": {
      "model": "ollama-cloud/glm-5"
    },
    "deep": {
      "model": "ollama-cloud/glm-5"
    },
    "ultrabrain": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "artistry": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "writing": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "visual-engineering": {
      "model": "ollama-cloud/minimax-m2.5"
    }
  }
}