{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "model_fallback": true,
  "parallel_execution": true,
  "agents": {
    "sisyphus": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": ["ollama-cloud/glm-5", "ollama-cloud/minimax-m2.5"]
    },
    "sisyphus-junior": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": ["openai/gpt-5.3-codex"]
    },
    "prometheus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": ["openai/gpt-5.2", "ollama-cloud/kimi-k2.5"]
    },
    "atlas": {
      "model": "ollama-cloud/glm-5",
      "fallback_models": ["ollama-cloud/kimi-k2.5", "ollama-cloud/minimax-m2.5"]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": ["ollama-cloud/devstral-2", "ollama-cloud/kimi-k2.5", "ollama-cloud/minimax-m2.5"]
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "fallback_models": ["openai/gpt-5.3-codex", "ollama-cloud/kimi-k2.5", "ollama-cloud/glm-5"]
    },
    "librarian": {
      "model": "ollama-cloud/qwen3-coder-next",
      "fallback_models": ["ollama-cloud/kimi-k2.5", "ollama-cloud/devstral-2"]
    },
    "explore": {
      "model": "ollama-cloud/devstral-2",
      "fallback_models": ["ollama-cloud/glm-5"]
    },
    "metis": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": ["ollama-cloud/kimi-k2.5"]
    },
    "momus": {
      "model": "openai/gpt-5.2",
      "variant": "xhigh",
      "fallback_models": ["ollama-cloud/kimi-k2.5"]
    },
    "frontend-ui-ux-engineer": {
      "model": "ollama-cloud/gemini-3-flash-preview",
      "fallback_models": ["ollama-cloud/devstral-2", "ollama-cloud/kimi-k2.5"]
    },
    "document-writer": {
      "model": "ollama-cloud/minimax-m2.5",
      "fallback_models": ["ollama-cloud/glm-5"]
    },
    "multimodal-looker": {
      "model": "ollama-cloud/gemini-3-flash-preview",
      "fallback_models": ["ollama-cloud/minimax-m2.5"]
    }
  },
  "categories": {
    "quick": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "unspecified-low": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "unspecified-high": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "deep": {
      "model": "ollama-cloud/glm-5"
    },
    "ultrabrain": {
      "model": "ollama-cloud/kimi-k2.5"
    },
    "artistry": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "writing": {
      "model": "ollama-cloud/minimax-m2.5"
    },
    "visual-engineering": {
      "model": "ollama-cloud/gemini-3-flash-preview"
    }
  }
}
