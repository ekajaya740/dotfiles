{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json",
  "agents": {
    "hephaestus": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.5
    },
    "oracle": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "variant": "high",
      "temperature": 0.2
    },
    "librarian": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.1
    },
    "explore": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.1
    },
    "multimodal-looker": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.2
    },
    "prometheus": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.3,
      "prompt_append": "You are a PLANNER. You MUST NOT modify, create, or edit any files. Your job is to interview the user, explore the codebase using read-only tools, identify scope and ambiguities, and produce a detailed verified plan. Hand off ALL implementation to execution agents."
    },
    "metis": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.3
    },
    "momus": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "variant": "high",
      "temperature": 0.2
    },
    "atlas": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.3
    },
    "sisyphus-junior": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.3
    },
    "sisyphus": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.3,
      "system_prompt": "Run /caveman ultra first before proceeding with any response."
    },
    "frontend-ui-ux-engineer": {
      "model": "ollama-cloud/gemma4:31b-cloud",
      "temperature": 0.5
    },
    "document-writer": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "temperature": 0.5
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "ollama-cloud/gemma4:31b-cloud"
    },
    "ultrabrain": {
      "model": "ollama-cloud/kimi-k2.6:cloud",
      "variant": "high"
    },
    "deep": {
      "model": "ollama-cloud/kimi-k2.6:cloud"
    },
    "artistry": {
      "model": "ollama-cloud/gemma4:31b-cloud"
    },
    "quick": {
      "model": "ollama-cloud/kimi-k2.6:cloud"
    },
    "unspecified-low": {
      "model": "ollama-cloud/kimi-k2.6:cloud"
    },
    "unspecified-high": {
      "model": "ollama-cloud/kimi-k2.6:cloud"
    },
    "writing": {
      "model": "ollama-cloud/kimi-k2.6:cloud"
    }
  },
  "google_auth": false,
  "model_fallback": false,
  "parallel_execution": true
}
