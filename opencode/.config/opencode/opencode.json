  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "grep_app": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 20000
    },
    "obsidian": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "$HOME/Documents/03-Resources/Second Brain"
      ],
      "enabled": true,
      "timeout": 20000
    },
    "notebooklm": {
      "type": "local",
      "command": [
        "bunx",
        "notebooklm-mcp@latest"
      ],
      "enabled": true,
      "timeout": 20000
    },
    "notion": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "mcp-remote",
        "https://mcp.notion.com/mcp"
      ],
      "enabled": true,
      "timeout": 20000
    }
  },
  "model": "openai/gpt-5.3-codex"
